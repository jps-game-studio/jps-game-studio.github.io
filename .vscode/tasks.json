{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "dev-server",
			"type": "shell",
			"command": "npm run dev",
			"isBackground": true,
			"problemMatcher": {
				"owner": "custom",
				"pattern": [
					{
						"regexp": ".",
						"file": 1,
						"location": 1,
						"message": 1
					}
				],
				"background": {
					"activeOnStart": true,
					"beginsPattern": "Race Legends dev server running at",
					"endsPattern": "Race Legends dev server running at"
				}
			}
		}
	]
}